#!/bin/bash
# Pre-commit hook for agent-game-engine
# Ensures code quality before committing

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track if any checks failed
FAILED=0

echo "========================================="
echo "Running pre-commit checks..."
echo "========================================="
echo ""

# Function to print colored status
print_status() {
    if [ $1 -eq 0 ]; then
        echo -e "${GREEN}✓${NC} $2"
    else
        echo -e "${RED}✗${NC} $2"
        FAILED=1
    fi
}

# Function to print fix suggestion
print_fix() {
    echo -e "${YELLOW}  → Fix: $1${NC}"
}

# 1. Check formatting
echo "1. Checking code formatting..."
if cargo fmt --check &>/dev/null; then
    print_status 0 "Code is properly formatted"
else
    print_status 1 "Code formatting issues found"
    print_fix "Run: cargo fmt"
fi
echo ""

# 2. Run clippy
echo "2. Running clippy lints..."
if cargo clippy --all-targets -- -D warnings &>/dev/null; then
    print_status 0 "No clippy warnings"
else
    print_status 1 "Clippy warnings found"
    print_fix "Run: cargo clippy --all-targets -- -D warnings"
    print_fix "Or fix automatically: cargo clippy --fix --all-targets"
fi
echo ""

# 3. Run quick unit tests
echo "3. Running unit tests..."
if cargo test --lib --quiet &>/dev/null; then
    print_status 0 "All unit tests passed"
else
    print_status 1 "Unit tests failed"
    print_fix "Run: cargo test --lib"
fi
echo ""

# 4. Check for banned dependencies (if cargo-deny is installed)
if command -v cargo-deny &> /dev/null; then
    echo "4. Checking dependencies..."
    if cargo deny check bans &>/dev/null; then
        print_status 0 "No banned dependencies"
    else
        print_status 1 "Banned dependencies found"
        print_fix "Run: cargo deny check bans"
    fi
    echo ""
else
    echo "4. Skipping dependency check (cargo-deny not installed)"
    echo "   Install with: cargo install cargo-deny"
    echo ""
fi

# 5. Check for common issues
echo "5. Checking for common issues..."
ISSUES=0

# Check for println/eprintln/dbg usage (should use tracing instead)
if git diff --cached --name-only | grep -E '\.rs$' | xargs grep -nE '(println!|eprintln!|dbg!)' 2>/dev/null; then
    ISSUES=1
    print_status 1 "Found println!/eprintln!/dbg! usage"
    print_fix "Use tracing instead: info!(), warn!(), error!(), debug!()"
fi

# Check for anyhow::Result usage (should use custom error types)
if git diff --cached --name-only | grep -E '\.rs$' | xargs grep -nE 'anyhow::Result' 2>/dev/null; then
    ISSUES=1
    print_status 1 "Found anyhow::Result usage"
    print_fix "Use custom error types (see docs/error-handling.md)"
fi

# Check for Box<dyn Error> usage (should use custom error types)
if git diff --cached --name-only | grep -E '\.rs$' | xargs grep -nE 'Box<dyn.*Error>' 2>/dev/null; then
    ISSUES=1
    print_status 1 "Found Box<dyn Error> usage"
    print_fix "Use custom error types (see docs/error-handling.md)"
fi

if [ $ISSUES -eq 0 ]; then
    print_status 0 "No common issues found"
fi
echo ""

# Final result
echo "========================================="
if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}All checks passed! Proceeding with commit.${NC}"
    echo "========================================="
    exit 0
else
    echo -e "${RED}Some checks failed. Please fix the issues above.${NC}"
    echo "========================================="
    echo ""
    echo "To bypass these checks (NOT recommended):"
    echo "  git commit --no-verify"
    echo ""
    exit 1
fi
