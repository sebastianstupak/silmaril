#!/bin/bash
# Pre-commit hook for agent-game-engine
# Ensures code quality before committing

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track if any checks failed
FAILED=0

echo "========================================="
echo "Running pre-commit checks..."
echo "========================================="
echo ""

# Function to print colored status
print_status() {
    if [ $1 -eq 0 ]; then
        echo -e "${GREEN}✓${NC} $2"
    else
        echo -e "${RED}✗${NC} $2"
        FAILED=1
    fi
}

# Function to print fix suggestion
print_fix() {
    echo -e "${YELLOW}  → Fix: $1${NC}"
}

# 1. Check formatting
echo "1. Checking code formatting..."
if cargo fmt --check &>/dev/null; then
    print_status 0 "Code is properly formatted"
else
    print_status 1 "Code formatting issues found"
    print_fix "Run: cargo fmt"
fi
echo ""

# 2. Run clippy
echo "2. Running clippy lints..."
if cargo clippy --all-targets -- -D warnings &>/dev/null; then
    print_status 0 "No clippy warnings"
else
    print_status 1 "Clippy warnings found"
    print_fix "Run: cargo clippy --all-targets -- -D warnings"
    print_fix "Or fix automatically: cargo clippy --fix --all-targets"
fi
echo ""

# 3. Run quick unit tests
echo "3. Running unit tests..."
if cargo test --lib --quiet &>/dev/null; then
    print_status 0 "All unit tests passed"
else
    print_status 1 "Unit tests failed"
    print_fix "Run: cargo test --lib"
fi
echo ""

# 4. Check for banned dependencies (if cargo-deny is installed)
if command -v cargo-deny &> /dev/null; then
    echo "4. Checking dependencies..."
    if cargo deny check bans &>/dev/null; then
        print_status 0 "No banned dependencies"
    else
        print_status 1 "Banned dependencies found"
        print_fix "Run: cargo deny check bans"
    fi
    echo ""
else
    echo "4. Skipping dependency check (cargo-deny not installed)"
    echo "   Install with: cargo install cargo-deny"
    echo ""
fi

# 5. Check for common issues
echo "5. Checking for common issues..."
ISSUES=0

# Check for println/eprintln/dbg usage (should use tracing instead)
if git diff --cached --name-only | grep -E '\.rs$' | xargs grep -nE '(println!|eprintln!|dbg!)' 2>/dev/null; then
    ISSUES=1
    print_status 1 "Found println!/eprintln!/dbg! usage"
    print_fix "Use tracing instead: info!(), warn!(), error!(), debug!()"
fi

# Check for anyhow::Result usage (should use custom error types)
if git diff --cached --name-only | grep -E '\.rs$' | xargs grep -nE 'anyhow::Result' 2>/dev/null; then
    ISSUES=1
    print_status 1 "Found anyhow::Result usage"
    print_fix "Use custom error types (see docs/error-handling.md)"
fi

# Check for Box<dyn Error> usage (should use custom error types)
if git diff --cached --name-only | grep -E '\.rs$' | xargs grep -nE 'Box<dyn.*Error>' 2>/dev/null; then
    ISSUES=1
    print_status 1 "Found Box<dyn Error> usage"
    print_fix "Use custom error types (see docs/error-handling.md)"
fi

if [ $ISSUES -eq 0 ]; then
    print_status 0 "No common issues found"
fi
echo ""

# 6. Check for forbidden documentation files (CLAUDE.md Rule #9)
echo "6. Checking for forbidden summary/implementation documents..."
FORBIDDEN_DOCS=0

# Define forbidden patterns
FORBIDDEN_PATTERNS=(
    "*_COMPLETE.md"
    "*_SUMMARY.md"
    "*_IMPLEMENTATION*.md"
    "*_STATUS.md"
    "*_REPORT.md"
    "*_RESULTS.md"
    "*_PLAN.md"
    "*_VALIDATION.md"
    "*_COMPARISON.md"
    "PHASE_*.md"
    "TASK_*.md"
    "AAA_*.md"
)

# Check staged files for forbidden patterns
STAGED_FILES=$(git diff --cached --name-only --diff-filter=A)
for pattern in "${FORBIDDEN_PATTERNS[@]}"; do
    # Convert glob pattern to regex
    regex="^${pattern//\*/.*}$"
    if echo "$STAGED_FILES" | grep -qE "$regex"; then
        FORBIDDEN_DOCS=1
        print_status 1 "Forbidden documentation file detected: $pattern"
    fi
done

if [ $FORBIDDEN_DOCS -eq 0 ]; then
    print_status 0 "No forbidden documentation files"
else
    print_fix "Remove summary/implementation/status documents (see CLAUDE.md Rule #9)"
    echo "    For progress → Use git commit messages"
    echo "    For architecture → Update docs/ (permanent docs)"
    echo "    For status → Update ROADMAP.md checkboxes"
    FAILED=1
fi
echo ""

# 7. Check for examples/ directories in engine crates (CLAUDE.md Rule #11)
echo "7. Checking for forbidden examples/ directories..."
FORBIDDEN_EXAMPLES=0

# Check for files in engine/*/examples/ (but not engine/shared/examples/)
FORBIDDEN_ENGINE_EXAMPLES=$(echo "$STAGED_FILES" | grep -E "^engine/[^/]+/examples/" | grep -vE "^engine/shared/examples/" || true)
if [ -n "$FORBIDDEN_ENGINE_EXAMPLES" ]; then
    FORBIDDEN_EXAMPLES=1
    print_status 1 "Forbidden examples/ directory in engine crate"
    echo "$FORBIDDEN_ENGINE_EXAMPLES" | sed 's/^/    /'
fi

# Check for non-game examples in top-level examples/ (CLAUDE.md Rule #11)
# Allowed: examples/{singleplayer,mmorpg,moba,turn-based}/
# Forbidden: examples/simple_demo, examples/ai_agent_debugger, etc.
ALLOWED_EXAMPLES_PATTERN="^examples/(singleplayer|mmorpg|moba|turn-based)/"
FORBIDDEN_ROOT_EXAMPLES=$(echo "$STAGED_FILES" | grep -E "^examples/" | grep -vE "$ALLOWED_EXAMPLES_PATTERN" || true)
if [ -n "$FORBIDDEN_ROOT_EXAMPLES" ]; then
    FORBIDDEN_EXAMPLES=1
    print_status 1 "Forbidden non-game example in examples/"
    echo "$FORBIDDEN_ROOT_EXAMPLES" | sed 's/^/    /'
fi

if [ $FORBIDDEN_EXAMPLES -eq 0 ]; then
    print_status 0 "No forbidden examples/ files"
fi

if [ $FORBIDDEN_EXAMPLES -ne 0 ]; then
    print_fix "Move examples to tests/ or benches/ (see CLAUDE.md Rule #11)"
    echo "    For API demos → Add rustdoc examples in src/"
    echo "    For functionality → Write integration tests in tests/"
    echo "    For performance → Write benchmarks in benches/"
    echo "    For full games only → Use examples/{singleplayer,mmorpg,moba,turn-based}/"
    FAILED=1
fi
echo ""

# 8. Check for performance tests in tests/ directory (CLAUDE.md Rule #10)
echo "8. Checking for performance tests in wrong location..."
MISPLACED_PERF=0

# Check for performance-related filenames in tests/
PERF_TEST_FILES=$(echo "$STAGED_FILES" | grep -E "^engine/.*/tests/.*performance.*\.rs$" || true)
if [ -n "$PERF_TEST_FILES" ]; then
    MISPLACED_PERF=1
    print_status 1 "Performance test in tests/ directory (should be in benches/)"
    echo "$PERF_TEST_FILES" | sed 's/^/    /'
fi

# Check for benchmark-related filenames in tests/
BENCH_TEST_FILES=$(echo "$STAGED_FILES" | grep -E "^engine/.*/tests/.*(bench|benchmark).*\.rs$" || true)
if [ -n "$BENCH_TEST_FILES" ]; then
    MISPLACED_PERF=1
    print_status 1 "Benchmark test in tests/ directory (should be in benches/)"
    echo "$BENCH_TEST_FILES" | sed 's/^/    /'
fi

# Check staged .rs files in tests/ for Instant::now() (performance measurement)
STAGED_TEST_FILES=$(echo "$STAGED_FILES" | grep -E "^engine/.*/tests/.*\.rs$" || true)
if [ -n "$STAGED_TEST_FILES" ]; then
    for file in $STAGED_TEST_FILES; do
        if git diff --cached "$file" | grep -qE '\+.*Instant::now\(\)'; then
            MISPLACED_PERF=1
            print_status 1 "Performance measurement (Instant::now) in tests/: $file"
            echo "    Line: $(git diff --cached "$file" | grep -E '\+.*Instant::now\(\)' | head -1)"
        fi
    done
fi

if [ $MISPLACED_PERF -eq 0 ]; then
    print_status 0 "No performance tests in wrong location"
else
    print_fix "Move performance tests to benches/ (see CLAUDE.md Rule #10)"
    echo "    Tests verify correctness → tests/"
    echo "    Benchmarks measure performance → benches/"
    echo "    If both needed → Split into 2 files"
    FAILED=1
fi
echo ""

# Final result
echo "========================================="
if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}All checks passed! Proceeding with commit.${NC}"
    echo "========================================="
    exit 0
else
    echo -e "${RED}Some checks failed. Please fix the issues above.${NC}"
    echo "========================================="
    echo ""
    echo "To bypass these checks (NOT recommended):"
    echo "  git commit --no-verify"
    echo ""
    exit 1
fi
