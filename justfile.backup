# Quick dev benchmarks (fast iteration)
dev-benchmark:
    #!/usr/bin/env python3
    import subprocess
    import sys

    print("Running Quick Benchmarks...")
    print()

    benchmarks = [
        ("ECS World", "engine-core", "world_benches"),
        ("ECS Query", "engine-core", "query_benches"),
        ("Math SIMD", "engine-math", "simd_benches"),
    ]

